# How your .env file should look. Fill in the API keys and adjust the config as needed.

# Groq (free — for email generation)
GROQ_API_KEY=your_key_here

# Hunter.io (free tier — for recruiter discovery)
HUNTER_API_KEY=your_key_here

# Pipeline config
MATCH_THRESHOLD=75
OUTREACH_THRESHOLD=80
RESUME_PATH=scorer/resume.pdf
DB_PATH=data/coie.db
RUN_TIME1=09:00
RUN_TIME2=18:00